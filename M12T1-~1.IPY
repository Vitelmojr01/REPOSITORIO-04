   "source": [
    "# Exercício 4 - item por item com impressão\n",
    "\n",
    "from sklearn.metrics import r2_score\n",
    "\n",
    "# ITEM 1 - obter o valor predito para tip_pct\n",
    "print(\"ITEM 1 - Obtendo os valores preditos para tip_pct\")\n",
    "pred = modelo_tip_pct.fittedvalues\n",
    "print(pred.head())\n",
    "\n",
    "# ITEM 2 - obter o valor predito para tip\n",
    "print(\"\\nITEM 2 - Calculando os valores preditos para tip\")\n",
    "gorjetas['tip_pred'] = pred * gorjetas['net_bill']\n",
    "print(gorjetas[['tip', 'tip_pred']].head())\n",
    "\n",
    "# ITEM 3 - calcular o R² do modelo para tip\n",
    "print(\"\\nITEM 3 - Calculando o R² do modelo para tip\")\n",
    "r2_tip_convertido = r2_score(gorjetas['tip'], gorjetas['tip_pred'])\n",
    "print(\"R² do modelo convertido para tip:\", r2_tip_convertido)\n",
    "\n",
    "# ITEM 4 - comparar com o R² do item 1\n",
    "print(\"\\nITEM 4 - Comparando os R²\")\n",
    "print(\"R² do modelo original (tip ~ net_bill):\", modelo.rsquared)\n",
    "print(\"R² do modelo percentual (tip_pct ~ net_bill):\", modelo_tip_pct.rsquared)\n",
    "print(\"R² do modelo convertido para tip:\", r2_tip_convertido)\n",
    "\n",
    "print(\"\\nCONCLUSÃO:\")\n",
    "print(\"O modelo direto de tip por net_bill tem melhor ajuste.\")"
   ]
